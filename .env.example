# ──────────────────────────────────────────────────────────────────────────────
# oapw — Environment Configuration
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# NEVER commit .env — it is already in .gitignore
# ──────────────────────────────────────────────────────────────────────────────


# ── Project ───────────────────────────────────────────────────────────────────

OAPW_PROJECT_NAME=my-app          # Used for cache namespacing
OAPW_DATA_DIR=.oapw               # Root dir for cache, DBs, traces


# ── Ollama (local LLM server) ─────────────────────────────────────────────────

OAPW_OLLAMA_BASE_URL=http://localhost:11434
OAPW_OLLAMA_DEFAULT_MODEL=qwen2.5:3b     # qwen2.5:7b on 16 GB machines
OAPW_OLLAMA_EMBED_MODEL=nomic-embed-text
OAPW_OLLAMA_TIMEOUT=120                  # seconds — increase on slow hardware


# ── Browser ───────────────────────────────────────────────────────────────────

OAPW_BROWSER_HEADLESS=true               # false to watch the browser during debug
OAPW_BROWSER_SLOW_MO=0                   # ms delay between actions (100 for debug)
OAPW_BROWSER_VIEWPORT_WIDTH=1280
OAPW_BROWSER_VIEWPORT_HEIGHT=720
OAPW_BROWSER_TIMEOUT=30000               # ms — default element wait timeout


# ── Application Under Test ────────────────────────────────────────────────────

OAPW_APP_BASE_URL=http://localhost:3000          # Base URL of your app
OAPW_APP_API_BASE_URL=http://localhost:3000/api  # API base URL (if different)


# ── Atlassian — Jira + Confluence ─────────────────────────────────────────────
# Used by: oapw kb sync --jira / --confluence
# API token is stored in OS keyring (NOT here):
#   Run once: poetry run oapw auth atlassian --email YOUR_EMAIL

OAPW_ATLASSIAN_URL=https://YOUR_COMPANY.atlassian.net
OAPW_ATLASSIAN_EMAIL=you@yourcompany.com


# ── Jira KB Sync — Project Keys ───────────────────────────────────────────────
# Used in the sync commands below — replace with your actual Jira project keys.
# Examples: AUTH, PLATFORM, MOBILE, BACKEND, FRONTEND

JIRA_PROJECT_KEYS=PROJECT1,PROJECT2       # comma-separated Jira project keys
JIRA_MAX_RESULTS=200                      # max tickets per sync run


# ── Bitbucket — Code Repository Sync ─────────────────────────────────────────
# Used by: oapw kb sync --repo ... --username ...
# App Password is stored in OS keyring (NOT here):
#   Run once: poetry run oapw auth bitbucket --username YOUR_USERNAME

BITBUCKET_USERNAME=your-bitbucket-username

# Space-separated list of repo clone URLs to sync
# Example: https://bitbucket.org/workspace/backend-api
BITBUCKET_REPO_1=https://bitbucket.org/YOUR_WORKSPACE/YOUR_REPO_1
BITBUCKET_REPO_2=https://bitbucket.org/YOUR_WORKSPACE/YOUR_REPO_2
BITBUCKET_REPO_3=                         # leave blank if fewer repos
BITBUCKET_BRANCH=main                     # branch to sync (main / master / develop)

# GitHub repos (no auth needed for public repos)
GITHUB_REPO_1=https://github.com/YOUR_ORG/YOUR_REPO_1
GITHUB_REPO_2=                            # leave blank if unused


# ── Hardware ──────────────────────────────────────────────────────────────────

OAPW_RAM_GB=8                             # 8 or 16 — used by oapw doctor


# ── Cache Tuning (optional — defaults are fine for most teams) ────────────────

OAPW_CACHE_L1_MAX_SIZE=512               # in-memory LRU entries
OAPW_CACHE_L2_TTL_LLM=2592000           # LLM cache TTL: 30 days (seconds)
OAPW_CACHE_L2_TTL_LOCATOR=604800        # locator cache TTL: 7 days
OAPW_CACHE_L2_TTL_PLAN=86400            # plan cache TTL: 1 day


# ── Agent Settings ────────────────────────────────────────────────────────────

OAPW_AGENT_MAX_STEPS=50                  # hard cap per AgentRunner run
OAPW_AGENT_MAX_STEP_RETRIES=2            # retries per failed step
OAPW_AGENT_LOOP_WINDOW=6                 # sliding window for cycle detection


# ── QA Agent ──────────────────────────────────────────────────────────────────

# Default: poetry run oapw qa "GOAL" --top-k 20
# Override top-k and investigation via CLI flags — no env var needed


# ── CI / GitHub Actions ───────────────────────────────────────────────────────
# These are set as GitHub repository secrets/variables, not in .env.
# Listed here for reference only:
#
# Secrets:
#   ATLASSIAN_TOKEN      → your Atlassian API token
#
# Variables (repo settings → Actions → Variables):
#   OAPW_APP_BASE_URL    → URL of the app under test in CI
#   OAPW_RUN_INTEGRATION → set to "true" to enable integration test job
